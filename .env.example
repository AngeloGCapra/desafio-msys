# Copie para .env e ajuste os valores. NUNCA commite o .env real.

# ----- PostgreSQL -----
POSTGRES_DB=desafio_msys
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ----- Back-end (Spring Boot) -----
# String de conexão usada pelo Spring (host "db" dentro do Docker; "localhost" no modo manual)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/desafio_msys
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
BACKEND_PORT=8080

# Segredo do JWT (use um valor longo e aleatório em uso real)
JWT_SECRET=troque-este-segredo-por-uma-chave-longa-e-aleatoria
# Validade do token em milissegundos (ex.: 3600000 = 1 hora)
JWT_EXPIRATION=3600000
# Origens permitidas no CORS (separadas por virgula). Default: origem do front em dev
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----- Front-end (Vite) -----
# URL base da API consumida pelo front
VITE_API_URL=http://localhost:8080
FRONTEND_PORT=5173
